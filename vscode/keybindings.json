// Place your key bindings in this file to override the defaultsauto[]
[
  // Mark: NAVIGATION
  // Group navigation
  {
    "key": "ctrl+h",
    "command": "workbench.action.focusLeftGroup"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.focusRightGroup"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.focusBelowGroup"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.focusAboveGroup"
  },
  // Tab navigation
  {
    "key": "shift+h",
    "command": "workbench.action.previousEditorInGroup",
    "when": "!inputFocus"
  },
  {
    "key": "shift+l",
    "command": "workbench.action.nextEditorInGroup",
    "when": "!inputFocus"
  },
  // Vim-like navigation on selection windows
  {
    "key": "ctrl+j",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetVisible"
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetVisible"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen"
  },

  // Terminal
  {
    "key": "ctrl+t",
    "command": "workbench.action.togglePanel",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+t",
    "command": "workbench.action.terminal.focus",
    "when": "!terminalFocus"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+n",
    "command": "workbench.action.terminal.new",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+shift+n",
    "command": "workbench.action.terminal.newWithProfile",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+q",
    "command": "workbench.action.terminal.kill",
    "when": "terminalFocus"
  },

  // FILE TREE
  // Toggle Visibility
  {
    "key": "ctrl+e",
    "command": "workbench.action.toggleSidebarVisibility"
  },
  {
    "key": "ctrl+e",
    "command": "workbench.files.action.focusFilesExplorer",
    "when": "editorTextFocus"
  },
  // Create stuff
  {
    "key": "n",
    "command": "explorer.newFile",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "shift+n",
    "command": "explorer.newFolder",
    "when": "explorerViewletFocus && !inputFocus"
  },
  // File-methods
  {
    "key": "x",
    "command": "filesExplorer.cut",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "y",
    "command": "filesExplorer.copy",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "p",
    "command": "filesExplorer.paste",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "r",
    "command": "renameFile",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "d",
    "command": "deleteFile",
    "when": "filesExplorerFocus && !inputFocus"
  },

  // Mimick leader behaviour
  {
    "key": "space f",
    "command": "workbench.action.quickOpen",
    "when": "!inputFocus"
  },
  {
    "key": "space z",
    "command": "workbench.action.toggleZenMode",
    "when": "!inputFocus"
  },
  {
    "key": "space =",
    "command": "workbench.action.evenEditorWidths",
    "when": "!inputFocus"
  },
  {
    "key": "space q",
    "command": "workbench.action.closeActiveEditor",
    "when": "!inputFocus"
  },
  {
    "key": "space x",
    "command": "workbench.action.closeActiveEditor",
    "when": "!inputFocus"
  },
  {
    "key": "space l",
    "command": "workbench.action.moveEditorToNextGroup",
    "when": "!inputFocus"
  },
  {
    "key": "space h",
    "command": "workbench.action.moveEditorToPreviousGroup",
    "when": "!inputFocus"
  },

  // EXTRA
  {
    "key": "ctrl+o",
    "command": "workbench.action.quickOpen",
    "when": "!editorTextFocus"
  },
  {
    "key": "ctrl+shift+o",
    "command": "workbench.action.files.openFileFolder"
  },
  // {
  //   "key": "shift+n",
  //   "command": "workbench.action.newWindow",
  //   "when": "!explorerViewletFocus && !editorTextFocus && !terminalFocus"
  // },
  {
    "key": "ctrl+n",
    "command": "openEditors.newUntitledFile",
    "when": "editorTextFocus && vim.mode != 'Normal' && vim.mode != 'Insert'"
  },
  {
    "key": "ctrl+z",
    "command": "workbench.action.toggleZenMode"
  },
  // Accept/decline selected suggestion or snippet
  {
    "key": "ctrl+a",
    "when": "(vim.mode == 'Insert' || vim.mode == 'Normal') && suggestWidgetVisible",
    "command": "acceptSelectedSuggestion"
  },

  // Mark: COPILOT EDITS
  // Scroll down half page in Normal mode (replaces vim's <C-d> which is now passed through)
  // Accept current change (hunk)
  {
    "key": "ctrl+a",
    "command": "chatEditor.action.acceptHunk",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Insert') && !suggestWidgetVisible"
  },
  // Decline current change (hunk)
  {
    "key": "ctrl+u",
    "command": "chatEditor.action.undoHunk",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Insert')"
  },
  // Accept all changes in file
  {
    "key": "ctrl+shift+a",
    "command": "chatEditor.action.accept",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Insert')"
  },
  // Decline all changes in file
  {
    "key": "ctrl+shift+u",
    "command": "chatEditor.action.reject",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Insert')"
  },
  // Go to next change
  {
    "key": "ctrl+n",
    "command": "chatEditor.action.navigateNext",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Insert')"
  },
  // Go to previous change
  {
    "key": "ctrl+p",
    "command": "chatEditor.action.navigatePrevious",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Insert')"
  }
]

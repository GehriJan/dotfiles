{
  "python.analysis.logLevel": "Trace",
  "python.languageServer": "Pylance",
  "files.autoSave": "afterDelay",
  "editor.wordWrap": "on",
  "telemetry.telemetryLevel": "error",
// Proxy settings
  "http.proxyStrictSSL": false,
  "http.proxy": "http://rb-proxy-de.bosch.com:8080",
  // "chat.proxyUrl": "http://@rb-proxy-de.bosch.com:8080",
//   "http.proxyAuthorization": null,
  "http.proxySupport": "override",
//   "window.enableExperimentalProxyLoginDialog": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "extensions.showRecommendationsOnlyOnDemand": true,
  "extensions.ignoreRecommendations": true,
  "extensions.autoUpdate": false,
  "workbench.editor.highlightModifiedTabs": true,
  "files.simpleDialog.enable": true,

  // VIM
  "vim.vimrc.enable": false,
  "vim.sneak": true,
  "vim.useSystemClipboard": false,
  "vim.leader": "<space>",
  "vim.ignorecase": true,
  "extensions.experimental.affinity": { "vscodevim.vim": 1 },
  "vim.insertModeKeyBindings": [
    { "before": ["k", "j"], "after": ["<Esc>", "l"] }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    { "before": ["k", "j"], "after": ["<Esc>", "l"] },

    { "before": ["j"], "after": ["g", "j"] },
    { "before": ["k"], "after": ["g", "k"] },

    // Stay in visual mode while indenting
    { "before": ["<"], "commands": ["editor.action.outdentLines"] },
    { "before": [">"], "commands": ["editor.action.indentLines"] },
    // Move selected lines while staying in visual mode
    { "before": ["J"], "commands": ["editor.action.moveLinesDownAction"] },
    { "before": ["K"], "commands": ["editor.action.moveLinesUpAction"] },
    // Toggle comment selection
    { "before": ["leader", "c"], "commands": ["editor.action.commentLine"] },
    // Keep focus centered
    { "before": ["n"], "after": ["n", "z", "z"] },
    { "before": ["N"], "after": ["N", "z", "z"] },

    { "before": ["leader", "b"], "commands": ["editor.action.formatDocument"] }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    // When going up and down keep cursor centered
    { "before": ["<C-d>"], "after": ["<C-d>", "z", "z"] },
    { "before": ["<C-u>"], "after": ["<C-u>", "z", "z"] },
    { "before": ["<C-b>"], "after": ["<C-b>", "z", "z"] },
    { "before": ["<C-f>"], "after": ["<C-f>", "z", "z"] },
    { "before": ["n"], "after": ["n", "z", "z"] },
    { "before": ["N"], "after": ["N", "z", "z"] },
    { "before": ["j"], "after": ["g", "j"] },
    { "before": ["k"], "after": ["g", "k"] },

    { "before": ["Y"], "after": ["y", "$"] },

    //Change "tab"
    { "before": ["<S-h>"], "commands": [":bprevious"] },
    { "before": ["<S-l>"], "commands": [":bnext"] },
    //resize window
    { "before": ["leader", "j"], "after": ["<C-w>", "-"] },
    { "before": ["leader", "k"], "after": ["<C-w>", "+"] },
    { "before": ["leader", "h"], "after": ["<C-w>", "<"] },
    { "before": ["leader", "l"], "after": ["<C-w>", ">"] },

    //Splits
    { "before": ["leader", "v"], "commands": [":vsplit"] },
    { "before": ["leader", "s"], "commands": [":split"] },

    //Quicker File closing/saving
    { "before": ["leader", "w"], "commands": [":w!"] },
    { "before": ["leader", "q"], "commands": [":q!"] },
    { "before": ["leader", "x"], "commands": [":x!"] },
    { "before": ["leader", "="], "after": ["<C-w>", "="] },

    { "before": ["leader", "f"], "commands": ["workbench.action.quickOpen"] },
    { "before": ["leader", "r"], "commands": ["editor.action.rename"] },
    { "before": ["leader", "g"], "commands": ["workbench.view.scm"] },
    { "before": ["leader", "/"], "commands": ["workbench.action.findInFiles"] },
    { "before": ["leader", "i"], "commands": ["workbench.action.chat.open"] },

    //commenting line
    { "before": ["leader", "c"], "commands": ["editor.action.commentLine"] },
    { "before": ["leader", "b"], "commands": ["editor.action.formatDocument"] },

    { "before": ["enter"], "after": ["o", "esc"] },
    { "before": ["<S-enter>"], "after": ["O", "esc"] },

    {
      "before": ["leader", "z"],
      "commands": ["workbench.action.toggleZenMode"]
    },

    { "before": ["leader", "p"], "after": ["\"", "+", "p"] },
    { "before": ["leader", "P"], "after": ["\"", "+", "P"] }
  ],
  "vim.useCtrlKeys": true,
  "vim.autoindent": true,
  "vim.statusBarColorControl": true,
  "vim.statusBarColors.normal": ["#8FBCBB", "#434C5E"],
  "vim.statusBarColors.insert": "#BF616A",
  "vim.statusBarColors.visual": "#B48EAD",
  "vim.statusBarColors.visualline": "#B48EAD",
  "vim.statusBarColors.visualblock": "#A3BE8C",
  "vim.statusBarColors.replace": "#D08770",
  "vim.statusBarColors.commandlineinprogress": "#007ACC",
  "vim.statusBarColors.searchinprogressmode": "#007ACC",
  "vim.statusBarColors.easymotionmode": "#007ACC",
  "vim.statusBarColors.easymotioninputmode": "#007ACC",
  "vim.statusBarColors.surroundinputmode": "#007ACC",
  "workbench.editorAssociations": {
    "*.pdf": "pdf.view",
    "*.svg": "defaultTextEditor"
  },
  "python.createEnvironment.trigger": "prompt",
  "terminal.integrated.fontFamily": "'Jetbrains Mono',Consolas, 'Courier New', monospace",
  "editor.codeLensFontFamily": "'Jetbrains Mono',Consolas, 'Courier New', monospace",
  "debug.console.fontFamily": "'Jetbrains Mono',Consolas, 'Courier New', monospace",
  "scm.inputFontFamily": "'Jetbrains Mono',Consolas, 'Courier New', monospace",

  "terminal.integrated.defaultProfile.windows": "PowerShell",

  "explorer.compactFolders": true,
  "files.trimTrailingWhitespace": true,
  "editor.formatOnType": true,
  "editor.formatOnPaste": true,
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontLigatures": true,
  "editor.accessibilitySupport": "off",
  "editor.lineHeight": 1.4,
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontSize": 14,
  "editor.tabSize": 4,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": false,
  "editor.autoIndent": "full",
  "editor.linkedEditing": true,
  "editor.lineNumbers": "relative",

  //Minimap and Scrollbar
  "editor.minimap.enabled": true,
  "editor.minimap.autohide": "mouseover",
  "editor.minimap.renderCharacters": false,
  "editor.minimap.maxColumn": 100,
  "editor.minimap.showSlider": "mouseover",
  "editor.minimap.scale": 1,
  "editor.minimap.showMarkSectionHeaders": true,
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.horizontal": "hidden",

  "window.commandCenter": false,
  "window.titleBarStyle": "custom",
  "workbench.editor.editorActionsLocation": "hidden",
  "workbench.editor.showTabs": "multiple",
  "workbench.layoutControl.enabled": false,
  "explorer.decorations.badges": true,
  "explorer.autoReveal": false,
  "debug.internalConsoleOptions": "neverOpen",
  "hediet.vscode-drawio.resizeImages": null,
  "workbench.colorCustomizations": {
    "statusBar.background": "#8FBCBB",
    "statusBar.noFolderBackground": "#8FBCBB",
    "statusBar.debuggingBackground": "#8FBCBB",
    "statusBar.foreground": "#434C5E",
    "statusBar.debuggingForeground": "#434C5E"
},
  "workbench.settings.openDefaultKeybindings": true,

  //Language specific stuff
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typst]": {
    "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?"
  },
  "[typst-code]": {
    "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?"
  },
  "[python]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.formatOnType": true,
    "editor.wordBasedSuggestions": "off",
    "editor.rulers": [100],
    "editor.defaultFormatter": "charliermarsh.ruff"
    // "editor.rulers": [79, 120]
  },
  "[latex]": {
    "editor.defaultFormatter": "James-Yu.latex-workshop"
  },
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "zenMode.hideLineNumbers": false,
  "workbench.editor.enablePreview": false,
  "security.workspace.trust.untrustedFiles": "open",
  "remote.defaultExtensionsIfInstalledLocally": [
    "GitHub.copilot",
    "GitHub.copilot-chat",
    "GitHub.vscode-pull-request-github"
  ],
  "jupyter.widgetScriptSources": ["jsdelivr.com", "unpkg.com"],
  "workbench.startupEditor": "none",
  "workbench.settings.editor": "json",
  "chat.agent.maxRequests": 40,
  "github.copilot.nextEditSuggestions.enabled": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
"workbench.colorTheme": "Gruvbox Dark Medium",
"github.copilot.enable": {
  "*": true,
  "plaintext": false,
  "markdown": true,
  "scminput": false
},
"git.replaceTagsWhenPull": true,
"chat.viewSessions.orientation": "stacked",
//   "python.defaultInterpreterPath": "c:\\Users\\gej5sgm\\AppData\\Local\\Programs\\Python\\Python313\\python.exe"
}
